// ====================
// ROOT
// ====================

file = {
    SOI
    ~ config?
    ~ declaration*
    ~ EOI
}

declaration = {
    enum_declaration
    | template_declaration
    | entity_declaration
}

// ====================
// CONFIG
// ====================

config = {
    "config" ~ "{" ~
        config_entry*
    ~ "}"
}

config_entry = {
    identifier ~ ":" ~ value
}

// ====================
// ENUM
// ====================

enum_declaration = {
    schema_prefix? ~ "enum" ~ identifier ~ "{" ~
        block_attribute*
        ~ enum_value+
        ~ block_attribute*
    ~ "}"
}

enum_value = {
    identifier
}

// ====================
// TEMPLATE
// ====================

template_declaration = {
    "template" ~ identifier ~ "{" ~
        (field | block_attribute)*
    ~ "}"
}

// ====================
// ENTITY
// ====================

entity_declaration = {
    schema_prefix? ~ "entity" ~ identifier
    ~ template_usage?
    ~ inheritance_usage?
    ~ "{" ~
        (field | block_attribute)*
    ~ "}"
}

template_usage = {
    ":" ~ identifier_list
}

inheritance_usage = {
    "inherits" ~ "(" ~ identifier_list ~ ")"
}

// ====================
// FIELDS
// ====================

field = {
    identifier ~ type_expr ~ field_attribute*
}

// ====================
// TYPES
// ====================

// Covers bare types (String, UUID) and parameterised types (VARCHAR(255), NUMERIC(10, 2))
type_expr = {
    identifier ~ type_params?
}

type_params = {
    "(" ~ value_list? ~ ")"
}

// ====================
// IDENTIFIERS
// ====================

identifier = @{
    (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")*
}

// Used in values - supports schema-qualified refs like User.id or "public".users
qualified_identifier = {
    (schema_prefix ~ ".")? ~ identifier ~ ("." ~ identifier)+
}

identifier_list = {
    identifier ~ ("," ~ identifier)* ~ ","?
}

// ====================
// ATTRIBUTES
// ====================

// Field-level: @id, @default(now()), @ref(User.id, on_delete: Cascade)
field_attribute = {
    "@" ~ identifier ~ attribute_args?
}

// Block-level: @@map("table_name"), @@index([col1, col2])
block_attribute = {
    "@@" ~ identifier ~ attribute_args
}

attribute_args = {
    "(" ~ argument_list? ~ ")"
}

argument_list = {
    argument ~ ("," ~ argument)* ~ ","?
}

argument = {
    named_argument
    | value
}

named_argument = {
    identifier ~ ":" ~ value
}

// ====================
// VALUES
// ====================

value = _{
    float_literal       // must come before integer_literal
    | integer_literal
    | list_literal
    | function_call     // must come before qualified_identifier (both start with identifier)
    | qualified_identifier
    | identifier
    | string_literal
}

value_list = {
    value ~ ("," ~ value)* ~ ","?
}

// ====================
// FUNCTION CALLS
// ====================

// Represents SQL/schema functions: now(), gen_random_uuid(), array_agg(col)
function_call = {
    identifier ~ "(" ~ value_list? ~ ")"
}

// ====================
// LITERALS
// ====================

string_literal = @{
    "\"" ~ ("\\\"" | !"\"" ~ ANY)* ~ "\""
}

integer_literal = @{
    ASCII_DIGIT+
}

float_literal = @{
    ASCII_DIGIT+ ~ "." ~ ASCII_DIGIT+
}

list_literal = {
    "[" ~ value_list? ~ "]"
}

// ====================
// SCHEMA PREFIX
// ====================

// A quoted schema name prefixing an entity or enum: "auth" enum Foo { ... }
schema_prefix = { string_literal }

// ====================
// WHITESPACE & COMMENTS
// ====================

WHITESPACE = _{ " " | "\t" | "\r\n" | "\n" }

COMMENT = _{ "//" ~ (!("\r\n" | "\n") ~ ANY)* }